{
  "compilerOptions": {
    "target": "es2017",
    "lib": ["dom", "esnext"],
    "resolveJsonModule": true,
    "moduleResolution": "bundler",
    "strict": true,
    "allowJs": true,
    "checkJs": false,
    "module": "esnext",
    "importHelpers": true,
    "outDir": "dist/",
    "declaration": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "types": ["bun"]
  },
  "include": [
    "index.ts",
    "src/**/*.ts",
    "build.ts",
    "scripts/**/*.ts",
    "test/**/*.ts",
    "lib/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
